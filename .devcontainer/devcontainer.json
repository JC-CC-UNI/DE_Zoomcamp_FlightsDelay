{
	"name": "Python 3",
	"image": "mcr.microsoft.com/devcontainers/python:1-3.11-bullseye",
    "postCreateCommand": "chmod +x .devcontainer/env_setup.sh && bash ./.devcontainer/env_setup.sh && chmod +x .devcontainer/exports.sh && bash ./.devcontainer/exports.sh",
	"postStartCommand": "git config --global --add safe.directory ${containerWorkspaceFolder}",
	"customizations": {
		"vscode": {
			"extensions": [
				"mechatroner.rainbow-csv",
				"VisualStudioExptTeam.vscodeintellicode",
				"donjayamanne.python-environment-manager",
				"innoverio.vscode-dbt-power-user"
			]
		},
		"settings": {
			"pythonPath": "/workspaces/DE_Zoomcamp_FlightsDelay/.data_eng_env/bin/python"
		}
	}
}
